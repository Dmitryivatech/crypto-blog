---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

// Если slug коллекции в админке другой — поменяй "tokens" здесь и в [slug].astro
const { entries: tokens, cacheHint } = await getEmDashCollection("tokens", {
	orderBy: { created_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base title="Tokens" description="Browse all tokens">
	<div class="tokens-page">
		<header class="page-header">
			<h1 class="page-title">Tokens</h1>
			<p class="page-description">
				{tokens.length}
				{tokens.length === 1 ? "token" : "tokens"}
			</p>
		</header>

		{
			tokens.length === 0 ? (
				<p class="empty">No tokens yet.</p>
			) : (
				<div class="tokens-grid">
					{tokens.map((token) => (
						<a href={`/tokens/${token.id}`} class="token-card">
							{token.data.type && (
								<span class="token-type">{token.data.type}</span>
							)}
							<h2 class="token-title">{token.data.title}</h2>
							{token.data.second_title && (
								<p class="token-subtitle">{token.data.second_title}</p>
							)}
						</a>
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.tokens-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.tokens-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-6);
	}

	.token-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
		padding: var(--spacing-6);
		background: var(--color-surface);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: inherit;
		transition: transform var(--transition-fast), border-color var(--transition-fast);
	}

	.token-card:hover {
		transform: translateY(-2px);
		border-color: var(--color-accent);
	}

	.token-type {
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.token-title {
		font-size: var(--font-size-xl);
		font-weight: 600;
		transition: color var(--transition-fast);
	}

	.token-card:hover .token-title {
		color: var(--color-accent);
	}

	.token-subtitle {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 900px) {
		.tokens-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-4);
		}
	}

	@media (max-width: 600px) {
		.tokens-grid {
			grid-template-columns: 1fr;
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}
	}
</style>
